PORT=3000

# JWT — bắt buộc ≥ 16 ký tự (đổi trên production)
JWT_SECRET=change-this-to-a-long-random-secret-min-16-chars
JWT_EXPIRES_IN=8h

ADMIN_EMAIL=admin@example.com
# bcrypt của mật khẩu ví dụ "123456" — tạo mới: npm run hash-admin-password -- <mật_khẩu>
ADMIN_PASSWORD_HASH='$2b$10$5rplbLnv88fdBXpADO8AKetVGu3cwP5jLC/uO88lHjVV179Mf0.U.'
VITE_API_URL=

# Vite dev server only: origin of the Express API for proxying `/api/*`
API_PROXY_TARGET=http://localhost:3000

# --- MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=shoe_rental_system_v2
DB_USER=root
DB_PASSWORD=
DB_CONNECTION_LIMIT=10

# --- Cloudinary (admin shoe images) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
