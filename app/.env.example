PORT=3000

# JWT — required, ≥ 16 characters (change in production)
JWT_SECRET=change-this-to-a-long-random-secret-min-16-chars
JWT_EXPIRES_IN=8h

# Auth: users live in MySQL `system_users` (password_hash bcrypt). Seed accounts: see ReCreateDB.sql
#   admin@gmail.com / Admin123!   ·   staff02@example.com / Password123!
VITE_API_URL=

# Vite dev server only: origin of the Express API for proxying `/api/*`
API_PROXY_TARGET=http://localhost:3000

# --- MoMo sandbox (optional online payment after rental checkout) ---
# When MOMO_ENABLED is not true or keys are missing, checkout skips MoMo and shows the success screen as before.
MOMO_ENABLED=false
MOMO_PARTNER_CODE=MOMO
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_PARTNER_NAME=Rental Shoe
MOMO_STORE_ID=RentalShoeStore
MOMO_API_HOST=https://test-payment.momo.vn
MOMO_API_PATH=/v2/gateway/api/create
# captureWallet opens MoMo hosted checkout (wallet / linked card). Use payWithMethod if your MoMo project requires it.
MOMO_REQUEST_TYPE=captureWallet
# Browser origin of the Vite app (redirect after MoMo payment — must match what you open in the browser)
FRONTEND_ORIGIN=http://localhost:5173
# Base URL MoMo calls for IPN (use ngrok or similar if MoMo cannot reach localhost)
API_PUBLIC_BASE_URL=http://localhost:3000
# Rental totals in the app are treated as USD; converted to VND for MoMo
PAYMENT_USD_TO_VND_RATE=25000

# --- MySQL ---
DB_HOST=localhost
DB_PORT=3333
DB_NAME=shoe_rental_system_v2
DB_USER=root
DB_PASSWORD=
DB_CONNECTION_LIMIT=10

# --- Cloudinary (admin shoe images) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
